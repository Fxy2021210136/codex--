# Required for a public deployment. Use a long random value.
ADMIN_TOKEN=replace-with-a-long-random-token

# Optional shared AI configuration. Providers: deepseek, gemini, openai.
# OpenAI uses the Responses API. Never commit real keys.
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
AI_API_KEY=

# Optional local Codex SDK bridge. Keep disabled on public multi-user deployments.
# Install requirements-codex.txt before enabling. Codex calls are admin-only.
ENABLE_CODEX_AGENT=0
CODEX_MODEL=gpt-5.4
CODEX_ALLOW_WRITE=0
CODEX_BIN=
CODEX_TIMEOUT_SECONDS=180

# Runtime settings
PORT=4173
APP_DATA_DIR=./data
# Optional. Defaults to sqlite:///APP_DATA_DIR/app.db
DATABASE_URL=
# Optional Windows-friendly alternative to DATABASE_URL
APP_DB_FILE=
AI_RATE_LIMIT_PER_MINUTE=10
AI_DAILY_LIMIT_PER_OWNER=20
CORS_ALLOWED_ORIGINS=
SESSION_TTL_SECONDS=2592000
APP_SECURE_COOKIES=0
PROJECT_LIMIT_PER_OWNER=20
LOGIN_FAILURE_LIMIT_PER_15_MINUTES=6
# Comma-separated emails that become admin after login.
ADMIN_EMAILS=

# Local default administrator password for the "管理员登录" tab.
# Change this before any public deployment.
ADMIN_DEFAULT_PASSWORD=177099

# Local testing only: return phone verification code to the browser.
# Set to 0 after connecting a real SMS provider.
PHONE_CODE_DEV_MODE=1

# Optional free email verification path. Leave off until SMTP is ready.
# EMAIL_VERIFICATION_MODE=off | smtp
EMAIL_VERIFICATION_MODE=off
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
