# Production-style environment template.
# Copy values into your hosting platform Secrets/Environment Variables.
# Never commit real secrets.

# Required. Generate with: .\scripts\new-admin-token.ps1
ADMIN_TOKEN=replace-with-a-long-random-token

# Your login email becomes an administrator after registration/login.
ADMIN_EMAILS=your-email@example.com

# Administrator password used by the built-in admin login tab.
# Replace 177099 with a long random secret before deployment.
ADMIN_DEFAULT_PASSWORD=replace-with-a-long-random-password

# Do not expose verification codes in public deployments.
# A real SMS provider should be connected before enabling phone-code login publicly.
PHONE_CODE_DEV_MODE=0

# Optional zero-cost email verification if you already have a free SMTP account.
# Keep off until EMAIL_SMTP_HOST and EMAIL_FROM are configured.
EMAIL_VERIFICATION_MODE=off
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=

# Public HTTPS deployments should use secure cookies.
APP_SECURE_COOKIES=1
SESSION_TTL_SECONDS=2592000

# Data persistence.
# Local containers may use sqlite:////data/app.db.
# Render Free must use the Neon connection string because its filesystem is temporary.
APP_DATA_DIR=/data
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Port is usually provided by the platform.
PORT=4173
CORS_ALLOWED_ORIGINS=

# AI gateway. Leave AI_API_KEY empty if you want local-rule mode only.
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
AI_API_KEY=
AI_RATE_LIMIT_PER_MINUTE=10
AI_DAILY_LIMIT_PER_OWNER=20

# Account and quota protection.
PROJECT_LIMIT_PER_OWNER=20
LOGIN_FAILURE_LIMIT_PER_15_MINUTES=6

# Keep Codex disabled on public multi-user deployments unless you fully control users.
ENABLE_CODEX_AGENT=0
CODEX_MODEL=gpt-5.4
CODEX_ALLOW_WRITE=0
CODEX_BIN=
CODEX_TIMEOUT_SECONDS=180
